<?xml version="1.0" encoding="UTF-8"?>
<!--
  Axon Outlook add-in - per-user MSI (no admin required).

  Does exactly what the Inno EXE (AxonOutlook.iss) does, so it "works the same":
    - installs AxonAddin.dll + ribbon icons to %LOCALAPPDATA%\AxonOutlook
    - registers the managed COM add-in under HKCU (per-user), same CLSID/ProgId
    - registers it under HKCU\...\Outlook\AddIns with LoadBehavior=3
    - writes %APPDATA%\AxonOutlook\config.json with both keys baked (never clobbers an existing one)

  Built by build-msi.ps1, which stages config.json (with the keys from assistant\.env) and passes
  its path via the StagedConfig preprocessor variable. IT can deploy the result machine-context via
  Intune/GPO in the user's context, or a user can double-click it (installs without admin).

  Build (see build-msi.ps1):
    candle.exe -dStagedConfig="...\config.json" AxonOutlook.wxs
    light.exe  -sval AxonOutlook.wixobj -o Axon-Outlook.msi
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <!-- ProductCode comes from build-msi.ps1, derived from the version: stable per version (so an RMM's
       captured code stays valid and uninstall-by-code never 1605s), and distinct across versions (so
       MajorUpgrade removes the old build instead of stacking a second copy). -->
  <Product Id="$(var.ProductCode)"
           Name="Axon Outlook add-in"
           Language="1033"
           Version="$(var.Version)"
           Manufacturer="Axon Group"
           UpgradeCode="E7A3C1B9-2F64-4D18-9A5C-1B7E3D9F62A4">

    <!-- Machine-wide install (needs admin): files land in C:\Program Files\Axon\Disassist and the add-in
         registers under HKLM, so it loads for EVERY user on the PC. IT pushes this as SYSTEM. -->
    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Description="Axon intelligence for Outlook"
             Manufacturer="Axon Group" />

    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of the Axon Outlook add-in is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Property Id="ARPNOMODIFY" Value="1" />

    <!-- Close Outlook BEFORE the file-in-use check (InstallValidate). If we wait until later, Windows
         Installer's Restart Manager has already shut Outlook down to free AxonAddin.dll and then RESTARTS
         it at the end of the transaction — so it comes back after "uninstall" and its handles keep the
         %APPDATA%\AxonOutlook residue locked. Killing it up front means Restart Manager never engages.
         Immediate action so it runs before InstallValidate; runs elevated (SYSTEM for an RMM push, the
         elevated admin for an interactive uninstall) — both can kill Outlook. Ask nicely, give it ~3s to
         save, then force. Only on uninstall/upgrade (the DLL is locked then), never on a first install. -->
    <CustomAction Id="KillOutlook" Directory="TARGETDIR" Execute="immediate" Return="ignore"
                  ExeCommand='cmd.exe /c taskkill /im OUTLOOK.EXE &amp; ping -n 4 127.0.0.1 &amp; taskkill /f /im OUTLOOK.EXE' />

    <!-- Wipe the per-user runtime data the add-in creates at run time (%APPDATA%\AxonOutlook: learned
         tone, archive memory, reminders). No installer ever tracked it, so it is what gets left behind.
         Runs as SYSTEM across every user profile, and ONLY on a real uninstall (not during an upgrade,
         which would otherwise delete a user's data on every version bump). Working dir is TARGETDIR (the
         drive root), NOT the install folder — RemoveFiles has already deleted the install folder by the
         time this runs, and cmd.exe cannot launch with a working directory that no longer exists. -->
    <CustomAction Id="CleanResidue" Directory="TARGETDIR" Execute="deferred" Impersonate="no" Return="ignore"
                  ExeCommand='cmd.exe /c for /d %A in ("%SystemDrive%\Users\*") do @rd /s /q "%A\AppData\Roaming\AxonOutlook" 2&gt;nul' />
    <InstallExecuteSequence>
      <Custom Action="KillOutlook"  Before="InstallValidate">REMOVE="ALL" OR WIX_UPGRADE_DETECTED</Custom>
      <Custom Action="CleanResidue" After="RemoveFiles">REMOVE="ALL" AND NOT UPGRADINGPRODUCTCODE</Custom>
    </InstallExecuteSequence>

    <!-- C:\Program Files\Axon\Disassist — the DLL, its ribbon icons and config.json all live together. -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="AxonFolder" Name="Axon">
          <Directory Id="INSTALLFOLDER" Name="Disassist" />
        </Directory>
      </Directory>
    </Directory>

    <!-- 1. The add-in DLL + its ribbon icons. -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="AddinFiles" Win64="yes" Guid="1C4E9A72-3B85-4F16-9D28-6A1B3E5C7D90">
        <File Id="AxonAddinDll" Name="AxonAddin.dll" Source="..\outlook_addin\AxonAddin.dll" KeyPath="yes" />
        <File Name="axon-move.png"      Source="..\outlook_addin\axon-move.png" />
        <File Name="axon-download.png"  Source="..\outlook_addin\axon-download.png" />
        <File Name="axon-summarize.png" Source="..\outlook_addin\axon-summarize.png" />
        <File Name="axon-reply.png"     Source="..\outlook_addin\axon-reply.png" />
        <File Name="axon-schedule.png"  Source="..\outlook_addin\axon-schedule.png" />
        <File Name="axon-followup.png"  Source="..\outlook_addin\axon-followup.png" />
        <File Name="axon-sendlater.png" Source="..\outlook_addin\axon-sendlater.png" />
        <File Name="axon-write.png"     Source="..\outlook_addin\axon-write.png" />
        <File Name="axon-attach.png"    Source="..\outlook_addin\axon-attach.png" />
        <File Name="axon-settings.png"  Source="..\outlook_addin\axon-settings.png" />
      </Component>

      <!-- 2. Managed COM registration under HKLM (machine-wide, 64-bit view for 64-bit Outlook). -->
      <Component Id="ComRegistration" Win64="yes" Guid="2D5F0B83-4C96-4A27-8E39-7B2C4F6D8E01">
        <RegistryKey Root="HKLM" Key="Software\Classes\Axon.OutlookAddin\CLSID">
          <RegistryValue Type="string" Value="{7B2C9E14-6A3D-4F58-9C21-3E5A1B7D4F60}" KeyPath="yes" />
        </RegistryKey>
        <RegistryKey Root="HKLM" Key="Software\Classes\CLSID\{7B2C9E14-6A3D-4F58-9C21-3E5A1B7D4F60}\InprocServer32">
          <RegistryValue Type="string" Value="[System64Folder]mscoree.dll" />
          <RegistryValue Type="string" Name="ThreadingModel" Value="Both" />
          <RegistryValue Type="string" Name="Class"          Value="Axon.OutlookAddin.Connect" />
          <RegistryValue Type="string" Name="Assembly"       Value="AxonAddin, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null" />
          <RegistryValue Type="string" Name="RuntimeVersion" Value="v4.0.30319" />
          <RegistryValue Type="string" Name="CodeBase"       Value="file:///[#AxonAddinDll]" />
        </RegistryKey>
        <RegistryKey Root="HKLM" Key="Software\Classes\CLSID\{7B2C9E14-6A3D-4F58-9C21-3E5A1B7D4F60}\InprocServer32\0.0.0.0">
          <RegistryValue Type="string" Name="Class"          Value="Axon.OutlookAddin.Connect" />
          <RegistryValue Type="string" Name="Assembly"       Value="AxonAddin, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null" />
          <RegistryValue Type="string" Name="RuntimeVersion" Value="v4.0.30319" />
          <RegistryValue Type="string" Name="CodeBase"       Value="file:///[#AxonAddinDll]" />
        </RegistryKey>
        <RegistryKey Root="HKLM" Key="Software\Classes\CLSID\{7B2C9E14-6A3D-4F58-9C21-3E5A1B7D4F60}\ProgId">
          <RegistryValue Type="string" Value="Axon.OutlookAddin" />
        </RegistryKey>
      </Component>

      <!-- 3. Tell Outlook to load it, for every user on this PC (HKLM add-in list). -->
      <Component Id="OutlookAddinReg" Win64="yes" Guid="3E60A194-5D07-4B38-9F4A-8C3D5E7F9012">
        <RegistryKey Root="HKLM" Key="Software\Microsoft\Office\Outlook\AddIns\Axon.OutlookAddin">
          <RegistryValue Type="integer" Name="LoadBehavior"  Value="3" KeyPath="yes" />
          <RegistryValue Type="string"  Name="FriendlyName"  Value="Axon intelligence" />
          <RegistryValue Type="string"  Name="Description"   Value="Summarize, reply, schedule, file and download emails with Axon" />
        </RegistryKey>
      </Component>

      <!-- 2b + 3b. The SAME registration in the 32-bit view (Wow6432Node), so 32-bit Outlook finds it
           too. The add-in DLL is AnyCPU, so it runs in either bitness; only the registry entries differ.
           Win64="no" writes to the 32-bit view, and the 32-bit CLR loader is SysWOW64\mscoree.dll (a
           64-bit mscoree cannot load into a 32-bit Outlook). Harmless on 64-bit-only machines. -->
      <Component Id="ComRegistration32" Win64="no" Guid="7C93E5D8-8A40-4E6C-B27D-5F0A7B912345">
        <RegistryKey Root="HKLM" Key="Software\Classes\Axon.OutlookAddin\CLSID">
          <RegistryValue Type="string" Value="{7B2C9E14-6A3D-4F58-9C21-3E5A1B7D4F60}" KeyPath="yes" />
        </RegistryKey>
        <RegistryKey Root="HKLM" Key="Software\Classes\CLSID\{7B2C9E14-6A3D-4F58-9C21-3E5A1B7D4F60}\InprocServer32">
          <RegistryValue Type="string" Value="[WindowsFolder]SysWOW64\mscoree.dll" />
          <RegistryValue Type="string" Name="ThreadingModel" Value="Both" />
          <RegistryValue Type="string" Name="Class"          Value="Axon.OutlookAddin.Connect" />
          <RegistryValue Type="string" Name="Assembly"       Value="AxonAddin, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null" />
          <RegistryValue Type="string" Name="RuntimeVersion" Value="v4.0.30319" />
          <RegistryValue Type="string" Name="CodeBase"       Value="file:///[#AxonAddinDll]" />
        </RegistryKey>
        <RegistryKey Root="HKLM" Key="Software\Classes\CLSID\{7B2C9E14-6A3D-4F58-9C21-3E5A1B7D4F60}\InprocServer32\0.0.0.0">
          <RegistryValue Type="string" Name="Class"          Value="Axon.OutlookAddin.Connect" />
          <RegistryValue Type="string" Name="Assembly"       Value="AxonAddin, Version=0.0.0.0, Culture=neutral, PublicKeyToken=null" />
          <RegistryValue Type="string" Name="RuntimeVersion" Value="v4.0.30319" />
          <RegistryValue Type="string" Name="CodeBase"       Value="file:///[#AxonAddinDll]" />
        </RegistryKey>
        <RegistryKey Root="HKLM" Key="Software\Classes\CLSID\{7B2C9E14-6A3D-4F58-9C21-3E5A1B7D4F60}\ProgId">
          <RegistryValue Type="string" Value="Axon.OutlookAddin" />
        </RegistryKey>
      </Component>
      <Component Id="OutlookAddinReg32" Win64="no" Guid="8D04F6E9-9B51-4F7D-C38E-6A1B8C023456">
        <RegistryKey Root="HKLM" Key="Software\Microsoft\Office\Outlook\AddIns\Axon.OutlookAddin">
          <RegistryValue Type="integer" Name="LoadBehavior"  Value="3" KeyPath="yes" />
          <RegistryValue Type="string"  Name="FriendlyName"  Value="Axon intelligence" />
          <RegistryValue Type="string"  Name="Description"   Value="Summarize, reply, schedule, file and download emails with Axon" />
        </RegistryKey>
      </Component>

      <!-- 4. config.json with both keys baked, NEXT TO THE DLL so every user on the PC reads it
           (a machine install can't write into each user's %APPDATA%). A user who wants their own
           model server can still drop a config.json in %APPDATA%\AxonOutlook, which wins. -->
      <Component Id="ConfigFile" Win64="yes" Guid="4F71B2A5-6E18-4C49-A05B-9D4E6F801123">
        <File Id="ConfigJson" Name="config.json" Source="$(var.StagedConfig)" KeyPath="yes" />
      </Component>

      <!-- 5. Scrub an older PER-USER install. HKCU COM registration takes precedence over HKLM, so a
           leftover per-user copy would shadow this machine-wide one and that user would keep running
           the old add-in. This reaches only the hive of whoever runs the MSI. -->
      <Component Id="CleanupPerUser" Win64="yes" Guid="5A82C3B6-7F29-4D5A-B16C-0E5F7A912234">
        <RegistryValue Root="HKLM" Key="Software\Axon\Disassist" Name="MachineWide" Type="integer" Value="1" KeyPath="yes" />
        <RemoveRegistryKey Root="HKCU" Key="Software\Classes\CLSID\{7B2C9E14-6A3D-4F58-9C21-3E5A1B7D4F60}" Action="removeOnInstall" />
        <RemoveRegistryKey Root="HKCU" Key="Software\Classes\Axon.OutlookAddin" Action="removeOnInstall" />
        <RemoveRegistryKey Root="HKCU" Key="Software\Microsoft\Office\Outlook\AddIns\Axon.OutlookAddin" Action="removeOnInstall" />
      </Component>

      <!-- 6. When IT pushes this as SYSTEM, the HKCU above is SYSTEM's hive, not the users'. Active Setup
           runs its StubPath ONCE for each user at their next sign-in — the supported way to reach every
           profile — so their stale per-user registration gets removed too. -->
      <Component Id="ActiveSetupCleanup" Win64="yes" Guid="6B93D4C7-8036-4E6B-A27D-1F608B023345">
        <RegistryKey Root="HKLM" Key="Software\Microsoft\Active Setup\Installed Components\{9F2E7A41-5C63-4B08-A7D9-3E1F6B84C205}">
          <RegistryValue Type="string" Value="Axon Disassist - remove old per-user add-in registration" KeyPath="yes" />
          <RegistryValue Type="string" Name="Version" Value="1,0,0,0" />
          <RegistryValue Type="string" Name="StubPath"
                         Value="cmd.exe /c reg delete &quot;HKCU\Software\Classes\CLSID\{7B2C9E14-6A3D-4F58-9C21-3E5A1B7D4F60}&quot; /f &amp; reg delete &quot;HKCU\Software\Classes\Axon.OutlookAddin&quot; /f &amp; reg delete &quot;HKCU\Software\Microsoft\Office\Outlook\AddIns\Axon.OutlookAddin&quot; /f" />
        </RegistryKey>
      </Component>
    </DirectoryRef>

    <Feature Id="MainFeature" Title="Axon Outlook add-in" Level="1">
      <ComponentRef Id="AddinFiles" />
      <ComponentRef Id="ComRegistration" />
      <ComponentRef Id="OutlookAddinReg" />
      <ComponentRef Id="ComRegistration32" />
      <ComponentRef Id="OutlookAddinReg32" />
      <ComponentRef Id="ConfigFile" />
      <ComponentRef Id="CleanupPerUser" />
      <ComponentRef Id="ActiveSetupCleanup" />
    </Feature>
  </Product>
</Wix>
